{
  "name": "fretboard",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check:no-inline-svg": "sh -c 'if rg \"<svg\" src --glob \"*.tsx\"; then echo \"Inline SVG found. Use lucide-react icons.\"; exit 1; fi'",
    "prepare": "simple-git-hooks"
  },
  "dependencies": {
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@tonaljs/chord": "^6.1.2",
    "lucide-react": "^1.16.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "smplr": "^0.26.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.10.0",
    "@types/react": "^18.3.20",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^5.1.0",
    "autoprefixer": "^10.4.20",
    "jsdom": "^26.1.0",
    "lint-staged": "^16.4.0",
    "postcss": "^8.4.47",
    "prettier": "^3.8.3",
    "simple-git-hooks": "^2.13.1",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.8.3",
    "vite": "^7.3.3",
    "vitest": "^3.2.4"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,css,scss,md,json,yml,yaml}": "prettier --write"
  }
}
